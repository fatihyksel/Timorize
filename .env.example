# MongoDB bağlantı dizesi (ör. mongodb://127.0.0.1:27017/timorize)
MONGODB_URI=mongodb://127.0.0.1:27017/timorize

# HTTP sunucu portu
PORT=3000

# JWT imzalama anahtarı (üretimde güçlü, rastgele bir değer kullanın)
JWT_SECRET=your-secret-key-change-in-production

# İsteğe bağlı: CORS kökenleri (virgülle ayrılmış)
# CORS_ORIGIN=http://localhost:5173,http://localhost:3000
